        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "TextBlock",
              "text": "5%",
              "size": "ExtraLarge",
              "weight": "Bolder",
              "horizontalAlignment": "Center",
              "color": "Accent"
            },
            {
              "type": "TextBlock",
              "text": "G. Completeness",
              "weight": "Bolder",
              "horizontalAlignment": "Center",
              "wrap": true
