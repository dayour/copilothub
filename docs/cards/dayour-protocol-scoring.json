            {
              "type": "TextBlock",
              "text": "C. UX Coherence",
              "weight": "Bolder",
              "horizontalAlignment": "Center",
              "wrap": true
            },
            {
              "type": "TextBlock",
              "text": "Visual consistency, interaction design, accessibility",
              "size": "Small",
              "isSubtle": true,
              "horizontalAlignment": "Center",
              "wrap": true
