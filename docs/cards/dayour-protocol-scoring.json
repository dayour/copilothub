    {
      "type": "Container",
      "style": "emphasis",
      "items": [
        {
          "type": "TextBlock",
          "text": "Synthesis Scoring Rubric",
          "size": "Large",
          "weight": "Bolder",
          "wrap": true
        },
        {
          "type": "TextBlock",
          "text": "DAYOUR Protocol | Pillar 2 of 5",
          "size": "Medium",
          "isSubtle": true,
          "spacing": "Small",
          "wrap": true
        }
      ],
      "bleed": true
    },
    {
      "type": "TextBlock",
      "text": "Composite Formula",
      "size": "Medium",
      "weight": "Bolder",
      "spacing": "Large",
      "wrap": true
    },
    {
      "type": "TextBlock",
      "text": "Composite = (A x 0.20) + (B x 0.20) + (C x 0.15) + (D x 0.20) + (E x 0.10) + (F x 0.10) + (G x 0.05)",
      "fontType": "Monospace",
      "wrap": true,
      "spacing": "Small"
    },
    {
      "type": "TextBlock",
      "text": "All dimensions scored 1--10. Composite ranges from 1.00 to 10.00.",
      "isSubtle": true,
      "size": "Small",
      "spacing": "Small",
      "wrap": true
    },
    {
      "type": "TextBlock",
      "text": "Scoring Dimensions",
      "size": "Medium",
      "weight": "Bolder",
      "spacing": "Large",
      "wrap": true
    },
    {
      "type": "ColumnSet",
      "spacing": "Medium",
      "columns": [
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "TextBlock",
              "text": "20%",
              "size": "ExtraLarge",
              "weight": "Bolder",
              "horizontalAlignment": "Center",
              "color": "Accent"
            },
            {
              "type": "TextBlock",
              "text": "A. Code Quality",
              "weight": "Bolder",
              "horizontalAlignment": "Center",
              "wrap": true
            },
            {
              "type": "TextBlock",
              "text": "TypeScript discipline, error handling, code organization",
              "size": "Small",
              "isSubtle": true,
              "horizontalAlignment": "Center",
              "wrap": true
            }
          ]
        },
        {
          "type": "Column",
          "width": "stretch",
