      "type": "Container",
      "style": "accent",
      "spacing": "Large",
      "items": [
        {
          "type": "TextBlock",
          "text": "Fluent 2 Design Compliance -- Dedicated 20% Dimension",
          "weight": "Bolder",
          "wrap": true
        },
        {
          "type": "TextBlock",
          "text": "Fluent 2 Design Compliance is a DEDICATED 20% dimension. Covers: color tokens, typography, spacing grid, elevation, motion, density, border radius, component patterns. Any hardcoded hex color not mapped through a Fluent 2 token is a compliance violation.",
          "wrap": true,
          "size": "Small"
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "Automated Quality Gates",
      "size": "Medium",
      "weight": "Bolder",
      "spacing": "Large",
      "wrap": true
    },
    {
      "type": "TextBlock",
      "text": "Binary PASS/FAIL checks that run before human scoring. Failures incur automatic penalties or block scoring.",
      "isSubtle": true,
      "size": "Small",
      "spacing": "Small",
      "wrap": true
    },
    {
      "type": "FactSet",
      "spacing": "Medium",
      "facts": [
        {
          "title": "tsc --noEmit",
          "value": "PASS/FAIL -- Zero errors required. FAIL blocks scoring."
        },
        {
          "title": "vitest run",
          "value": "Min 80% pass rate. FAIL = -2.0 composite penalty."
        },
        {
          "title": "Regression Check",
          "value": "All baseline tests must pass. FAIL blocks scoring."
        },
        {
          "title": "Bundle Size Delta",
          "value": "Warn if >10% increase. -0.5 penalty per 10% over threshold."
        },
        {
          "title": "Fluent 2 Audit",
          "value": "No hardcoded hex colors. Each violation = -0.1 from Dim B."
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "Merge Decision Matrix",
      "size": "Medium",
      "weight": "Bolder",
      "spacing": "Large",
      "wrap": true
